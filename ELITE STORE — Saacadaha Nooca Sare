.edit-input { width: 100%; background: var(--ink); border: 1px solid rgba(201, 205, 211, 0.2); color: var(--cream); border-radius: 6px; padding: 6px 8px; font-size: 12.5px; font-family: Inter, sans-serif; }

.loading { color: var(--steel-light); font-size: 13px; padding: 30px; text-align: center; }

.wa-float { position: fixed; bottom: 22px; right: 22px; z-index: 60; width: 56px; height: 56px; border-radius: 50%; background: rgb(37, 211, 102); display: flex; align-items: center; justify-content: center; box-shadow: rgba(0, 0, 0, 0.4) 0px 8px 20px; text-decoration: none; font-size: 28px; transition: transform 0.2s; }

