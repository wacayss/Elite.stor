.chat-float { position: fixed; bottom: 22px; left: 22px; z-index: 60; width: 56px; height: 56px; border-radius: 50%; background: var(--emerald); border: none; display: flex; align-items: center; justify-content: center; box-shadow: rgba(0, 0, 0, 0.4) 0px 8px 20px; font-size: 26px; cursor: pointer; transition: transform 0.2s; color: var(--cream); }

