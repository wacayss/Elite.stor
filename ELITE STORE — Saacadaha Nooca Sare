@charset "utf-8";

:root { --ink: #14161a; --charcoal: #1c1f24; --steel: #3a3e45; --steel-light: #5a5f68; --silver: #c9cdd3; --emerald: #2f8f6a; --emerald-light: #4ab389; --brass: #c9a227; --brass-light: #e0bd4e; --cream: #f3f1ec; --danger: #c14b3f; }

* { box-sizing: border-box; margin: 0px; padding: 0px; }

html { scroll-behavior: smooth; }

body { background: var(--ink); color: var(--cream); font-family: Inter, sans-serif; min-height: 100vh; }

.display { font-family: "Bodoni Moda", serif; }

header { position: sticky; top: 0px; z-index: 50; background: rgba(20, 22, 26, 0.9); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(201, 205, 211, 0.12); padding: 18px 24px; display: flex; align-items: center; justify-content: space-between; }

.logo { font-family: "Bodoni Moda", serif; font-weight: 900; font-size: 22px; letter-spacing: 2px; color: var(--cream); display: flex; align-items: center; gap: 10px; }

.logo .dot { color: var(--emerald-light); }

.head-actions { display: flex; align-items: center; gap: 10px; }

.icon-btn { position: relative; background: transparent; border: 1px solid var(--steel-light); color: var(--cream); width: 44px; height: 44px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: border-color 0.2s; font-size: 16px; }

.icon-btn:hover { border-color: var(--brass-light); }

.cart-count { position: absolute; top: -6px; right: -6px; background: var(--brass); color: var(--ink); font-size: 11px; font-weight: 700; width: 19px; height: 19px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }

.hero { position: relative; padding: 70px 24px 60px; display: flex; flex-direction: column; align-items: center; text-align: center; overflow: hidden; }

.hero::before { content: ""; position: absolute; top: -120px; left: 50%; transform: translateX(-50%); width: 520px; height: 520px; border-radius: 50%; background: radial-gradient(circle at 50% 45%, rgba(47, 143, 106, 0.16), transparent 70%); pointer-events: none; }

